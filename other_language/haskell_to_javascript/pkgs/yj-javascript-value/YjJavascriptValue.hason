{-# OPTIONS_GHC -Wall -fno-warn-tabs #-}

module YjJavascriptValue (pkg) where

import Hason

pkg :: Hason
pkg = [	(KStr "name", Str "yj-javascript-value"),
	(KStr "version", Str "0.1.0.0"),
	(KStr "exposed-modules", Seq [
		Str "GHC.JS.Value",
		Str "GHC.JS.Value.String",
		Str "GHC.JS.Value.Object",
		Str "GHC.JS.Value.Array" ]),
	(KStr "depends", Seq [
		Dct [	(KStr "name", Str "base"),
			(KStr "version", Str "4.21.2.0") ] ]) ]
