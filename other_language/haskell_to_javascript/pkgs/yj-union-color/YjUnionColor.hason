{-# OPTIONS_GHC -Wall -fno-warn-tabs #-}

module YjColor(pkg) where

import Hason

pkg :: Hason
pkg = [	(KStr "name", Str "yj-union-color"),
	(KStr "version", Str "0.1.0.0"),
	(KStr "exposed-modules", Seq [
		Str "Data.UnionColor",
		Str "Data.UnionColor.Internal",
		Str "Data.UnionColor.Internal.GrayScale"
		]),
	(KStr "depends", Seq [
		Dct [	(KStr "name", Str "base"),
			(KStr "version", Str "4.21.2.0") ] ]) ]
