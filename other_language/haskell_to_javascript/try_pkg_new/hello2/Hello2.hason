{-# OPTIONS_GHC -Wall -fno-warn-tabs #-}

module Hello2(pkg) where

import Hason

pkg :: Hason
pkg = [	(KStr "name", Str "hello2"),
	(KStr "version", Str "0.1.0.0"),
	(KStr "exposed-modules", Seq [Str "Hello2"]),
	(KStr "other-modules", Seq []),
	(KStr "depends", Seq [
		Dct [	(KStr "name", Str "base"),
			(KStr "version", Str "4.20.0.0") ] ]) ]
